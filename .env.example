# Copy to .env and fill in. Only ANTHROPIC_API_KEY is required to run the agent.
ANTHROPIC_API_KEY=

# Fallback provider, used only if Anthropic fails
GROQ_API_KEY=

# Telegram bot token for comunication
TELEGRAM_BOT_TOKEN=

# Defaults to a local SQLite file. Point at a Postgres/Supabase URL for production.
DATABASE_URL=sqlite:///screening.db